# Apify API token — get from https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Anthropic API key — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Instagram accounts to monitor (comma-separated)
IG_COMPETITORS=herbaldynamics,ancientnutrition,amazinggrass,gardenoflife

# Hashtags to track (comma-separated, without #)
IG_HASHTAGS=blackseedoil,nigellasativa,naturalremedies,holistichealth,blackseedoilbenefits

# Brand Instagram handle
IG_BRAND_HANDLE=majublackseedoil

# Research cycle settings
POSTS_PER_ACCOUNT=30
POSTS_PER_HASHTAG=50
MIN_ENGAGEMENT_RATE=2.0
